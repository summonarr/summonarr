{
  "name": "summonarr",
  "version": "0.16.2",
  "private": true,
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=22 <27"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "node node_modules/tsgo/bin/tsc --noEmit",
    "typecheck:classic": "node node_modules/typescript/bin/tsc --noEmit",
    "audit:deps": "node scripts/audit-deps.mts",
    "audit:routes": "node scripts/audit-routes.mts",
    "audit:openapi": "node scripts/audit-openapi.mts",
    "test": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --import ./tests/_loader.mjs --test tests/*.test.mts",
    "smoke:security": "tsx scripts/smoke-test-security.ts",
    "licenses:generate": "node scripts/generate-licenses.mts",
    "licenses:check": "node scripts/generate-licenses.mts --check",
    "postinstall": "node scripts/patch-eslint-plugin-react.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "jose": "^6.2.3",
    "next": "16.2.10",
    "openid-client": "^6.8.4",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "overrides": {
    "@babel/core": "^7.29.6",
    "defu": ">=6.1.5",
    "@hono/node-server": "^1.19.14",
    "brace-expansion@5": "^5.0.6",
    "hono": "^4.12.25",
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "^26.1.0",
    "@types/pg": "^8.11.14",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^10.7.0",
    "eslint-config-next": "16.2.10",
    "eslint-plugin-react-hooks": "^7.1.1",
    "playwright": "^1.61.1",
    "tailwindcss": "^4.3.1",
    "tsgo": "npm:typescript@^7.0.2",
    "tsx": "^4.23.1",
    "typescript": "^7"
  }
}
