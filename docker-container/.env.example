# ─── Database ─────────────────────────────────────────────────────────────────
# Password for the PostgreSQL user. This is the ONLY database value you set in
# the published image: the entrypoint builds the connection string from it
# (postgresql://summonarr:<this>@postgres:5432/summonarr) and the bundled
# Postgres container initializes with it, so the two always match. There is no
# DATABASE_URL knob here — the entrypoint overrides it unconditionally.
# Generate one with: openssl rand -base64 32
POSTGRES_PASSWORD=

# ─── TMDB ────────────────────────────────────────────────────────────────────
# Required for movie/TV search and poster images.
#
#   TMDB_READ_TOKEN  — v4 Read Access Token. Sent as a bearer header, so the key
#                      never appears in upstream access logs.
#
# Get one at: https://www.themoviedb.org/settings/api
TMDB_READ_TOKEN=

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Random secret used to sign session tokens. MUST be at least 32 characters.
# The app refuses to boot in production if this is missing or too short.
# Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET=

# REQUIRED for security: the public URL of this app.
# NextAuth uses this as the fixed base URL for OAuth callbacks and redirects,
# preventing Host-header injection attacks when running behind a reverse proxy.
# Examples: http://localhost:3001  |  https://requests.yourdomain.com
AUTH_URL=http://localhost:3001

# ─── Base Path ────────────────────────────────────────────────────────────
# Set to run the app under a subpath (e.g. /request) behind a reverse proxy.
# Must start with a slash and NOT end with one. Example: /request
# Leave blank to serve from the root path.
BASE_PATH=

# ─── Reverse Proxy ────────────────────────────────────────────────────────────
# Set to "true" when the app runs behind a trusted reverse proxy (Nginx, Traefik,
# Caddy, etc.) that sets X-Forwarded-For / X-Real-IP. Enables per-IP rate limiting.
#
# Any other value (including "false" or unset) puts the app in LOCAL-ONLY mode:
# - Boot is allowed (no startup exit), so local builds and LAN-only deployments
#   work without configuring a proxy.
# - The app rejects every request whose Host header is not localhost, a docker
#   loopback address, or an RFC1918 LAN address — public-DNS access returns 403.
# - Per-IP rate limiting is disabled and all requests share a single bucket.
#
# Use TRUST_PROXY=true for any deployment reachable from the public internet.
TRUST_PROXY=

# Optional comma-separated list of additional trusted origins beyond AUTH_URL.
# Add any domain that is allowed to make authenticated API calls to this app,
# e.g. a staging URL, an internal service hostname, or a LAN address.
# Example: https://staging.yourdomain.com,http://192.168.1.10:3000
AUTH_TRUSTED_ORIGIN=

# ─── Cron ─────────────────────────────────────────────────────────────────────
# Secret used by the built-in sync scheduler to authenticate internal cron calls.
# MUST be at least 32 characters — the app refuses to boot in production if this
# is missing or too short. For extra protection against `docker inspect`
# exposure, mount a Docker/Swarm secret at /run/secrets/cron_secret and the
# entrypoint will read it from there instead.
# Generate one with: openssl rand -base64 32
CRON_SECRET=

# ─── Encryption at rest ──────────────────────────────────────────────────────
# 32-byte (exactly 64 hex character) key used to encrypt sensitive Setting rows
# (API keys, webhook secret, SMTP password, TRaSH GitHub token, etc.) and
# Account / Push tokens via AES-256-GCM. When unset, values are stored plaintext
# — rollout is non-breaking, but set this for production. The app refuses to
# boot in production if this is set to anything other than 64 hex chars.
# Generate one with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# ─── Backups ──────────────────────────────────────────────────────────────────
# Password used to encrypt and decrypt full-database backups (AES-256-GCM,
# PBKDF2-SHA256). Required to use the Backup & Restore admin page — both
# export and import endpoints return 503 until this is set.
# MUST be at least 12 characters. Losing it makes every prior encrypted backup
# unrecoverable — store it in a password manager.
# Generate one with: openssl rand -base64 32
BACKUP_DB_PASSWORD=

# ─── OIDC / SSO ──────────────────────────────────────────────────────
# Set all three to enable "Sign in with SSO" via any OpenID Connect provider
# (Authelia, Auth0, Keycloak, Authentik, Okta, etc.).
# The issuer must support .well-known/openid-configuration discovery.
# Example: OIDC_ISSUER=https://auth.yourdomain.com
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# Optional display name shown on the login button (default: "SSO")
OIDC_DISPLAY_NAME=

# Escape hatch for OAuth/OIDC/Plex/Jellyfin-only deployments that have NO local
# credentials (username/password) setup flow. By default the first-ever OAuth
# sign-in is NOT promoted to ADMIN — this prevents an attacker who reaches the
# OAuth/Plex flow before you finish setup from inheriting admin. Set to "true"
# only on a fresh OAuth-only install to let your first sign-in become ADMIN,
# then remove it once that admin exists.
# SUMMONARR_ALLOW_OAUTH_FIRST_ADMIN=true

# ─── Jellyfin ─────────────────────────────────────────────────────────────────
# There is no Jellyfin env var. Configure Jellyfin entirely in the app:
# Admin → Settings → Media → set the server URL + API key. Both standard and
# QuickConnect Jellyfin login turn on automatically once those are saved.

# ─── Image version ────────────────────────────────────────────────────────────
# Pin to a specific release tag (recommended in production). Defaults to
# "latest" when unset. Example: SUMMONARR_VERSION=v0.9.0
SUMMONARR_VERSION=

# ─── Schedule tuning (optional) ───────────────────────────────────────────────
# All values are in seconds. Defaults shown — override only if you need to.
# The Docker compose file passes these straight through to the container.
# SYNC_INTERVAL=3600                # Plex + Jellyfin library + Radarr/Sonarr wanted refresh
# UPCOMING_SYNC_INTERVAL=86400      # TMDB upcoming titles
# RATINGS_SYNC_INTERVAL=86400       # MDBList / OMDB ratings
# LIST_CACHE_SYNC_INTERVAL=21600    # Discover-page list cache
# WARM_ACTIVITY_INTERVAL=1800       # 365-day activity heatmap pre-compute
# WARM_MDBLIST_INTERVAL=86400       # MDBList cache warmer
# WARM_OMDB_INTERVAL=86400          # OMDB cache warmer
# PLAY_HISTORY_SYNC_INTERVAL=5      # Active-session poll (fast loop)
# PURGE_SESSIONS_INTERVAL=86400     # Expired auth-session purge
# SCRUB_AUDIT_PII_INTERVAL=86400    # Audit-log PII scrubber
# TRASH_SYNC_INTERVAL=86400         # TRaSH-Guides catalog refresh

# ─── Advanced / rarely needed ─────────────────────────────────────────────────
# Max concurrent SSE (/api/events) connections AND the per-emitter listener cap —
# one knob bounds both. Default 500; raise only for very large deployments.
# SSE_MAX_LISTENERS=500

# Delayed-jobs queue bounds (see src/lib/delayed-jobs.ts). Defaults shown.
# DELAYED_JOBS_MAX_PENDING=500
# DELAYED_JOBS_MAX_QUEUE=100
# DELAYED_JOBS_MAX_CONCURRENCY=4
