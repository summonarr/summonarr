generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ───────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid(2))
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  // Set when the credentials password is changed. refreshToken() rejects any JWT
  // whose iat predates this — replica-safe revocation without an in-memory Set.
  passwordChangedAt DateTime?
  // Set when revokeAllUserSessions runs. Same comparison as passwordChangedAt;
  // gives admins a one-shot "log this user out everywhere" primitive that is
  // honored on every replica's next refresh.
  sessionsRevokedAt DateTime?
  // Set when the user self-deletes their account (App Store Guideline 5.1.1(v)).
  // The row is ANONYMIZED in place — PII scrubbed, provider-subject keys + OAuth
  // rows cleared — so their requests/votes/issues survive de-identified, but the
  // account can never sign in again. Excluded from the "last active admin" count.
  deactivatedAt DateTime?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  discordId     String?   @unique
  // Legacy authorization booleans — migrated into permission bits
  // (AUTO_APPROVE / QUOTA_UNLIMITED) by scripts/migrate-role-permissions.mjs.
  // Kept (deprecated) so the migration can read them; dropped in a follow-up
  // once every environment has migrated. New code reads `permissions` instead.
  autoApprove   Boolean   @default(false)
  quotaExempt   Boolean   @default(false)

  // ─── Authorization (Overseerr-style) ─────────────────────────────────────
  // `permissions` is the AUTHORITATIVE capability bitmask; `role` above is now a
  // coarse PRESET that seeds it (see PRESETS in src/lib/permissions.ts) and a
  // label still used for admin-area gating in proxy.ts. Stored as BIGINT because
  // a JS Int bitmask overflows at bit 31 (bitwise ops are signed-32-bit) and the
  // 4K block crosses 30 bits. Carried in the session JWT as a decimal string
  // (BigInt is not JSON-serializable). 0 = unseeded → callers fall back to the
  // role preset via effectivePermissions(), so an upgrade can run `prisma db
  // push` before the migration without locking anyone out.
  permissions   BigInt    @default(0)
  // Per-user, per-media-type request-quota overrides. null ⇒ use the global
  // quotaLimit/quotaPeriod Settings. QUOTA_UNLIMITED (or ADMIN) bypasses both.
  movieQuotaLimit Int?
  movieQuotaDays  Int?
  tvQuotaLimit    Int?
  tvQuotaDays     Int?

  // Parental control: the maximum US content rating this user may request. null ⇒
  // no cap. Enforced at the request chokepoint (src/lib/content-rating.ts); ADMIN
  // bypasses. Stored as an MPAA cap ("G".."NC-17") that governs BOTH movies and TV
  // via a unified maturity rank.
  maxContentRating String?

  // For local/OIDC users: which media server's availability badges to show ("plex" | "jellyfin" | null)
  // Plex and Jellyfin OAuth users derive this from their auth provider automatically.
  mediaServer   String?

  // Delivery address for outgoing email notifications. Separate from `email`
  // (which is the login identity and may be a synthetic jellyfin-<id>@jellyfin.local
  // placeholder for Jellyfin users). For Plex/OIDC/credentials users this is
  // auto-synced to the source email on every sign-in. For Jellyfin users it is
  // null until the user sets it manually on the profile page and is never
  // auto-populated from the Jellyfin server.
  notificationEmail String?

  // Canonical X-Plex-Client-Identifier for this user — pinned after first successful Plex sign-in.
  // Handed back to any browser this user later signs in from so subsequent sign-ins reuse the
  // same clientId, avoiding the "Another device is attempting to sign in" warning on Plex's
  // OAuth approval page (Plex only warns on clientIds not yet registered to the user's account).
  plexClientId String?

  // Provider subject identity. For Plex/Jellyfin (Credentials providers — NextAuth's
  // Account table doesn't apply), we bind sign-in to (provider, sub) instead of email
  // to defeat email-collision auto-link. Populated on first successful sign-in.
  // If a sign-in arrives whose Plex/Jellyfin id collides with an existing user row's
  // email but not its plexUserId/jellyfinUserId, sign-in is REFUSED.
  plexUserId     String? @unique
  jellyfinUserId String? @unique

  // Discord notification preferences (opt-in by default)
  notifyOnApproved  Boolean @default(true)
  notifyOnAvailable Boolean @default(true)
  notifyOnDeclined  Boolean @default(true)

  // Email notification preferences (opt-out by default for users)
  emailOnApproved  Boolean @default(false)
  emailOnAvailable Boolean @default(false)
  emailOnDeclined  Boolean @default(false)

  // Admin/issue-admin notification preferences
  notifyOnIssue Boolean @default(true)

  // Push notification preferences (opt-in by default)
  pushOnApproved  Boolean @default(true)
  pushOnAvailable Boolean @default(true)
  pushOnDeclined  Boolean @default(true)

  accounts          Account[]
  sessions          Session[]
  requests          MediaRequest[]
  issues            Issue[]            @relation(name: "IssueReporter")
  claimedIssues     Issue[]            @relation(name: "IssueClaimer")
  issueMessages     IssueMessage[]
  issueGrabs        IssueGrab[]
  pushSubscriptions PushSubscription[]
  deletionVotes     DeletionVote[]
  discordLinkToken  DiscordLinkToken?
  discordMergeCode  DiscordMergeCode?
  mediaServerUsers  MediaServerUser[]
  authSessions      AuthSession[]
  watchlist         WatchlistItem[]
  hidden            HiddenItem[]
}

model PushSubscription {
  id          String   @id @default(cuid(2))
  userId      String
  endpoint    String   @unique
  platform    String   @default("web") // "web" (VAPID Web Push) | "ios" (APNs)
  p256dh      String? // web only (VAPID)
  auth        String? // web only (VAPID)
  deviceToken String? // ios only — APNs device token, encrypted at the route (guardrail 7a)
  publicKey   String? // ios only — device P-256 public key (X9.63 base64) for E2E push; public, NOT encrypted
  label       String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                String  @id @default(cuid(2))
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid(2))
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// One record per active JWT auth session. Created at sign-in, deleted on sign-out or revocation.
// Enables per-device session listing, forced logout, and cross-replica revocation via DB.
model AuthSession {
  id          String   @id @default(cuid(2))
  sessionId   String   @unique @db.VarChar(64) // mirrors JWT token.sessionId
  userId      String
  deviceType  String   @db.VarChar(16) // "mobile" | "tablet" | "desktop"
  deviceLabel String?  @db.VarChar(256) // e.g. "Chrome on Windows"
  ipAddress   String?  @db.VarChar(64)
  createdAt   DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  expiresAt   DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ─── Discord Linking ──────────────────────────────────────────────────────────

model DiscordLinkToken {
  token     String   @id
  userId    String   @unique
  discordId String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DiscordMergeCode {
  userId    String   @unique
  discordId String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Requests ───────────────────────────────────────────────────────────────

model MediaRequest {
  id                  String        @id @default(cuid(2))
  mediaType           MediaType
  tmdbId              Int
  title               String        @db.VarChar(500)
  posterPath          String?       @db.VarChar(500)
  releaseYear         String?       @db.VarChar(16)
  status              RequestStatus @default(PENDING)
  note                String?       @db.VarChar(500)
  adminNote           String?       @db.VarChar(500)
  permanentlyDeclined Boolean       @default(false)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  tvdbId Int? // set for TV shows when added to Sonarr; used for webhook matching

  // Which Radarr/Sonarr instance this request targets. false = HD (default),
  // true = the optional 4K instance. Part of the unique key so one user can hold
  // both an HD and a 4K request for the same title.
  is4k Boolean @default(false)

  // Optional per-request quality profile chosen by a REQUEST_ADVANCED user (or an
  // admin at approve time). null ⇒ use the target instance's configured default.
  // Flows to addMovieToRadarr/addSeriesToSonarr as the qualityProfileIdOverride.
  qualityProfileId Int?

  lastArrPushAt     DateTime? // last Radarr/Sonarr add attempt (success or fail); gates the sync re-push backoff for APPROVED items never accepted upstream
  availableAt       DateTime? // set once when status transitions to AVAILABLE; used for fulfillment-time stats
  pendingNotifyAt   DateTime? // set to approvedAt+90s; cleared once the pending/awaiting notification fires
  notifiedAvailable Boolean   @default(false) // set when the "ready to watch" notification is sent; never reset on status revert

  requestedBy String
  user        User   @relation(fields: [requestedBy], references: [id], onDelete: Cascade)

  @@unique([tmdbId, mediaType, requestedBy, is4k])
  @@index([requestedBy])
  @@index([status])
  @@index([tvdbId])
  @@index([status, availableAt])
  @@index([notifiedAvailable])
}

// ─── Plex Library Cache ───────────────────────────────────────────────────────

model PlexLibraryItem {
  tmdbId        Int
  mediaType     MediaType
  filePath      String?
  plexRatingKey String? // Plex internal ratingKey — needed to call fix-match API
  title         String?
  year          String?
  overview      String?
  contentRating String? // e.g. "PG-13", "R", "TV-MA" — from Plex contentRating field
  addedAt       DateTime? // when the item was added to the Plex library

  @@id([tmdbId, mediaType])
  @@index([plexRatingKey]) // play-history sync filters on plexRatingKey every poll
  @@index([addedAt]) // /admin/activity/recent orders by addedAt desc; without an index this seq-scans the full library every render
}

// ─── Jellyfin Library Cache ───────────────────────────────────────────────────

model JellyfinLibraryItem {
  tmdbId          Int
  mediaType       MediaType
  filePath        String?
  jellyfinItemId  String? // Jellyfin internal item UUID — needed to call fix-match API
  title           String?
  year            String?
  overview        String?
  contentRating   String? // e.g. "PG", "R", "TV-14" — from OfficialRating field
  communityRating Float? // Jellyfin community rating (0–10)
  addedAt         DateTime? // when the item was added to Jellyfin (DateCreated)

  @@id([tmdbId, mediaType])
  @@index([jellyfinItemId]) // play-history sync filters on jellyfinItemId every poll
  @@index([addedAt]) // /admin/activity/recent orders by addedAt desc; without an index this seq-scans the full library every render
}

// ─── TV Episode Cache ─────────────────────────────────────────────────────────
// Populated during sync; stores season+episode granularity for TV shows.
// source = "plex" | "jellyfin"

model TVEpisodeCache {
  source        String
  tmdbId        Int
  seasonNumber  Int
  episodeNumber Int

  // Episode metadata — populated as a side-effect of season expand fetches
  episodeName String?
  airDate     String?
  stillPath   String?
  runtime     Int?
  overview    String?

  @@id([source, tmdbId, seasonNumber, episodeNumber])
  @@index([source, tmdbId])
}

// ─── Radarr Wanted Cache ──────────────────────────────────────────────────────
// Movies in Radarr that have no file yet (monitored/unmonitored, not downloaded).
// Populated by /api/sync/radarr; cleared per-movie by the Radarr webhook on Download.

model RadarrWantedItem {
  tmdbId Int
  is4k   Boolean @default(false) // false = HD instance, true = 4K instance

  @@id([tmdbId, is4k])
}

// ─── Radarr Available Cache ───────────────────────────────────────────────────
// Movies in Radarr that have a file (hasFile=true).
// Populated atomically with RadarrWantedItem by /api/sync/radarr.
// Enables DB-only availability checks — avoids per-movie ?tmdbId= API calls.

model RadarrAvailableItem {
  tmdbId Int
  is4k   Boolean @default(false) // false = HD instance, true = 4K instance

  @@id([tmdbId, is4k])
}

// ─── Sonarr Wanted Cache ──────────────────────────────────────────────────────
// TV shows in Sonarr that have zero downloaded episode files.
// Populated by /api/sync/sonarr; cleared per-series by the Sonarr webhook on Download.

model SonarrWantedItem {
  tmdbId Int
  is4k   Boolean @default(false) // false = HD instance, true = 4K instance

  @@id([tmdbId, is4k])
}

// ─── Sonarr Available Cache ───────────────────────────────────────────────────
// TV shows in Sonarr that have at least one downloaded episode file (episodeFileCount > 0).
// Populated atomically with SonarrWantedItem by /api/sync/sonarr.
// Enables DB-only availability checks — avoids per-series ?tmdbId= API calls.

model SonarrAvailableItem {
  tmdbId Int
  is4k   Boolean @default(false) // false = HD instance, true = 4K instance

  @@id([tmdbId, is4k])
}

// ─── Upcoming Cache ───────────────────────────────────────────────────────────
// Populated by /api/sync/upcoming; full replacement each sync.
// Stores TMDB upcoming movies (/movie/upcoming) and on-the-air TV (/tv/on_the_air).

model UpcomingCacheItem {
  tmdbId       Int
  mediaType    MediaType
  title        String
  overview     String
  posterPath   String?
  backdropPath String?
  releaseDate  String?
  releaseYear  String
  voteAverage  Float
  cachedAt     DateTime  @default(now())

  @@id([tmdbId, mediaType])
}

// ─── TMDB Cache ───────────────────────────────────────────────────────────────
// Generic key-value store for TMDB API responses.
// key examples: "movie:123:details", "tv:456:credits", "person:789", "genres:movie"
// data is JSON-serialised. expiresAt is checked before returning cached data.

model TmdbCache {
  key       String   @id
  data      String // JSON
  cachedAt  DateTime @default(now())
  expiresAt DateTime

  @@index([expiresAt])
}

// ─── TMDB Media Core ──────────────────────────────────────────────────────────
// Normalized store for core media metadata (title, poster, year, rating,
// certification) used by every grid page. Populated as a fire-and-forget
// side-effect of detail fetches, prewarm, and trending/popular/discover calls.
// Enables grid pages to avoid TmdbCache JSON blob parsing on every load.

model TmdbMediaCore {
  tmdbId        Int
  mediaType     MediaType
  title         String
  posterPath    String?
  releaseYear   String?
  voteAverage   Float     @default(0)
  certification String?
  lastSyncedAt  DateTime  @default(now())
  expiresAt     DateTime

  @@id([tmdbId, mediaType])
  @@index([expiresAt])
  @@index([mediaType, voteAverage])
}

// ─── Discord Search Cache ────────────────────────────────────────────────────
// Stores Discord /request search results (keyed by q:{type}:{query}) and
// pending selection state (keyed by p:{interactionId}:{discordUserId}).
// Survives server restarts; expired rows are cleaned up by a daily cron job.

model DiscordSearchCache {
  queryKey  String   @id
  data      String // JSON
  expiresAt DateTime

  @@index([expiresAt])
}

// ─── Settings ────────────────────────────────────────────────────────────────

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Caches a SHA-256 hash of each Plex authToken → verified email so subsequent
// sign-ins can skip the /api/v2/user call (which fires Plex "new device" alerts
// from the server's IP). Cache hits are revalidated via /api/v2/ping, which
// returns no user data and doesn't trigger device alerts.
model PlexTokenCache {
  tokenHash  String   @id
  email      String
  // Plex provider subject id (User.plexUserId). Nullable for legacy rows
  // written before this column existed. The cache-hit path looks up the
  // bound User row by this id rather than email — email is reassignable in
  // Plex, so binding by id prevents a different account whose email matches
  // a stale cache row from inheriting that row's identity. Legacy nulls
  // force a Plex round-trip (which repopulates the column).
  plexUserId String?
  verifiedAt DateTime @default(now())
  lastUsedAt DateTime @default(now()) @updatedAt
  // Optional: legacy rows (pre-TTL migration) have null. Auth flow populates
  // on every cache touch (lastUsedAt + 90 days). Sweeper in maintenance.ts
  // purges both expired rows AND legacy nulls — the worst case for a null row
  // is one extra Plex /api/v2/user call on next sign-in.
  expiresAt  DateTime?

  @@index([email])
  @@index([expiresAt])
  @@index([plexUserId])
}

// ─── Issues ──────────────────────────────────────────────────────────────────

model Issue {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reportedBy String
  user       User   @relation(name: "IssueReporter", fields: [reportedBy], references: [id], onDelete: Cascade)

  // Optional admin/issue-admin claim. When set, notifications for replies on
  // this issue narrow to the claimer + reporter (instead of all admins).
  claimedBy   String?
  claimedAt   DateTime?
  claimedUser User?     @relation(name: "IssueClaimer", fields: [claimedBy], references: [id], onDelete: SetNull)

  mediaType  MediaType
  tmdbId     Int
  tvdbId     Int?
  title      String     @db.VarChar(500)
  posterPath String?    @db.VarChar(500)

  issueType     IssueType
  scope         IssueScope @default(FULL)
  seasonNumber  Int?
  episodeNumber Int?
  note          String?    @db.VarChar(2000)

  status     IssueStatus @default(OPEN)
  resolution String?     @db.VarChar(2000)

  messages IssueMessage[]
  grabs    IssueGrab[]

  @@index([reportedBy])
  @@index([claimedBy])
  @@index([status])
}

model IssueMessage {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())

  issueId String
  issue   Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  body      String  @db.VarChar(10000)
  fromAdmin Boolean @default(false)

  @@index([issueId])
  @@index([authorId])
}

// ─── Issue Grabs ─────────────────────────────────────────────────────────────
// Tracks each release grab an admin triggers for an issue so that we can
// send them a push notification when the download completes via webhook.

model IssueGrab {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())

  issueId String
  issue   Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)

  triggeredById String
  triggeredBy   User   @relation(fields: [triggeredById], references: [id], onDelete: Cascade)

  tmdbId        Int
  tvdbId        Int?
  mediaType     MediaType
  title         String
  scope         IssueScope
  seasonNumber  Int?
  episodeNumber Int?

  notifiedAt DateTime? // set when the completion push is sent; prevents duplicate notifications

  @@index([issueId])
  @@index([triggeredById])
  @@index([tmdbId, mediaType, notifiedAt]) // every Radarr/Sonarr Download webhook does findMany(notifiedAt: null) by (tmdbId, mediaType) — without this it seq-scans on every grab
}

// ─── Deletion Votes ──────────────────────────────────────────────────────
// Users nominate library items for removal. The first vote creates the nomination;
// subsequent votes from other users increase the count. Admin can review
// top-voted items and decide whether to delete.

model DeletionVote {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())

  tmdbId     Int
  mediaType  MediaType
  title      String  @db.VarChar(500)
  posterPath String? @db.VarChar(500)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  reason String? @db.VarChar(200)

  @@unique([tmdbId, mediaType, userId]) // one vote per user per item
  @@index([tmdbId, mediaType])
}

// ─── Audit Log ───────────────────────────────────────────────────────────────

model AuditLog {
  id        String      @id @default(cuid(2))
  createdAt DateTime    @default(now())
  userId    String?     @db.VarChar(64)
  userName  String      @db.VarChar(256)
  action    AuditAction
  target    String      @db.VarChar(500)
  details   String?     @db.VarChar(8000)
  ipAddress String?     @db.VarChar(64)
  userAgent String?     @db.VarChar(512)
  provider  String?     @db.VarChar(32)
  sessionId String?     @db.VarChar(64)

  @@index([createdAt(sort: Desc)])
  @@index([action])
  @@index([userId])
  @@index([userName])
  @@index([target])
  @@index([userId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
}

// ─── Request Blacklist ─────────────────────────────────────────────────────────
// Admin-maintained titles that are hidden from discovery AND blocked at the
// request chokepoint. Keyed by (tmdbId, mediaType) — the app's canonical media
// identity (matches PlexLibraryItem / TmdbMediaCore).

model BlacklistItem {
  tmdbId    Int
  mediaType MediaType
  title     String?  @db.VarChar(500) // denormalized so the admin list needn't re-fetch TMDB
  reason    String?  @db.VarChar(500)
  addedBy   String?  // admin User id; nullable + no FK so user-anonymize can't cascade-delete entries
  createdAt DateTime @default(now())

  @@id([tmdbId, mediaType])
  @@index([createdAt])
}

enum AuditAction {
  REQUEST_APPROVE
  REQUEST_DECLINE
  REQUEST_DELETE
  REQUEST_ON_BEHALF
  USER_CREATE
  USER_ROLE_CHANGE
  USER_PERMISSIONS_CHANGE
  USER_DELETE
  SETTINGS_CHANGE
  LIBRARY_SYNC
  ISSUE_STATUS_CHANGE
  ISSUE_CLAIM
  ISSUE_UNCLAIM
  MAINTENANCE_TOGGLE
  BACKUP_EXPORT
  BACKUP_IMPORT
  AUTH_LOGIN
  AUTH_LOGIN_FAILED
  AUTH_LOGOUT
  SESSION_REVOKE
  CACHE_WARM
  RATINGS_CACHE_CLEAR
  ISSUE_DELETE
  CONTENT_REPORT
  PLAY_HISTORY_BACKFILL
  PLAY_HISTORY_DELETE
  PLAY_HISTORY_EXPORT
  AUDIT_LOG_EXPORT
  FIX_MATCH
  BATCH_REQUEST_DECLINE
  VOTE_DISMISS_ALL
  SERVER_USERS_BULK
  PLEX_SESSION_TERMINATE
  JELLYFIN_SESSION_TERMINATE
  BLACKLIST_CHANGE
}

// ─── Play History ────────────────────────────────────────────────────────────
// Tracks playback sessions from Plex and Jellyfin — Tautulli-style analytics.

model MediaServerUser {
  id               String   @id @default(cuid(2))
  source           String // "plex" | "jellyfin"
  sourceUserId     String // Plex accountID or Jellyfin userId UUID
  // Server machineIdentifier (Plex) or System/Info Id (Jellyfin) the row was first
  // observed on. Currently DORMANT scaffolding: the only writer is the trusted
  // play-history poller, which does not pass a machineId, so this stays null in
  // practice. The verification branch in resolveMediaServerUser
  // (MediaServerMismatchError) only fires if a future *untrusted* ingestion path
  // passes one. The Plex/Jellyfin webhook handlers this comment once referenced
  // were removed — do not treat this as an active security control.
  serverMachineId  String?
  username         String
  email            String?
  thumbUrl         String?
  userId           String? // FK to User — nullable for unlinked server users
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  downloadsEnabled Boolean? // null = not yet synced; true = allowed; false = enforced-disabled
  isServerAdmin    Boolean  @default(false) // cached from server — admins are never touched by bulk enforcement
  // false = removed from the media server (soft-deleted). NEVER hard-delete a
  // MediaServerUser: PlayHistory + ActiveSession FK it (now onDelete: Restrict)
  // and play history must survive a user's removal. The Jellyfin prune sets this
  // false instead of deleting; the next sync re-activates a returning user.
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  playHistory    PlayHistory[]
  activeSessions ActiveSession[]

  @@unique([source, sourceUserId])
  @@index([userId])
  @@index([source])
}

model PlayHistory {
  id     String @id @default(cuid(2))
  source String @db.VarChar(16) // "plex" | "jellyfin"

  // Session timing
  startedAt      DateTime
  stoppedAt      DateTime
  duration       Int // Total duration of media in seconds
  playDuration   Int // Wall-clock seconds the session was in the "playing" state (excludes pause/buffer). Accumulated on ActiveSession.playtimeMs across every state-change event.
  pausedDuration Int      @default(0) // (stoppedAt - startedAt) - playDuration. Approximation of paused/buffering time.
  watched        Boolean  @default(false) // playDuration / duration >= playHistoryWatchedThreshold (default 80%)
  completed      Boolean  @default(false) // Final playhead position / duration >= 95%

  // User
  mediaServerUserId String
  mediaServerUser   MediaServerUser @relation(fields: [mediaServerUserId], references: [id], onDelete: Restrict)

  // Media identification
  tmdbId        Int?
  mediaType     MediaType?
  title         String     @db.VarChar(500)
  year          String?    @db.VarChar(16)
  posterPath    String?    @db.VarChar(500)
  seasonNumber  Int?
  episodeNumber Int?
  episodeTitle  String?    @db.VarChar(500)

  // Source-specific keys (for deduplication)
  sourceSessionId String?  @db.VarChar(256)
  sourceItemId    String?  @db.VarChar(256)

  // Playback metadata
  platform  String?        @db.VarChar(256)
  player    String?        @db.VarChar(256)
  device    String?        @db.VarChar(256)
  ipAddress String?        @db.VarChar(64)

  // Transcode info
  playMethod    String?    @db.VarChar(32) // "DirectPlay" | "DirectStream" | "Transcode"
  videoCodec    String?    @db.VarChar(64)
  audioCodec    String?    @db.VarChar(64)
  resolution    String?    @db.VarChar(32)
  bitrate       Int? // kbps
  videoDecision String?    @db.VarChar(32)
  audioDecision String?    @db.VarChar(32)
  container     String?    @db.VarChar(32)
  transcodeReason String?  @db.VarChar(500) // Why the server transcoded, from Plex transcodeSession / Jellyfin TranscodingInfo.TranscodeReasons. Comma-joined when multiple. Null/Unknown for sessions recorded before this was captured.

  // Network / connection metadata (Plex). Populated from /status/sessions
  // Session and Player sub-objects: location is "lan" | "wan" | "relay",
  // bandwidth is the server-reported session bandwidth in kbps, secure
  // reflects whether the client connected over HTTPS, relayed indicates
  // playback travelled through plex.tv's relay proxy.
  location  String? @db.VarChar(16)
  bandwidth Int? // kbps
  secure    Boolean?
  relayed   Boolean?

  // Intro/credits markers from /library/metadata/{ratingKey}?includeMarkers=1.
  // Offsets are in milliseconds relative to the start of the file. Stored on
  // PlayHistory so completion + watched detection can treat content end at
  // creditsStartMs rather than raw duration (Plex clients commonly leave the
  // player at viewOffset ≈ duration even when the user actually stopped at
  // the credits roll, undercounting "watched" at the default 80% threshold).
  introStartMs    Int?
  introEndMs      Int?
  creditsStartMs  Int?
  creditsEndMs    Int?

  // Resume-grouping. Set to the previous PlayHistory.id when this row is
  // the continuation of an unwatched watch of the same media by the same
  // user (Tautulli-style reference_id). UI groups history rows sharing a
  // referenceId chain so "paused on Monday, finished on Tuesday" shows as
  // one logical viewing. Self-link when the row starts its own chain — see
  // applyResumeGrouping in src/lib/play-history.ts.
  referenceId String? @db.VarChar(32)

  createdAt DateTime @default(now())

  @@unique([source, sourceSessionId])
  @@index([mediaServerUserId, startedAt(sort: Desc)])
  @@index([tmdbId, mediaType])
  @@index([startedAt(sort: Desc)])
  @@index([source])
  @@index([source, sourceSessionId])
  @@index([source, sourceItemId, mediaServerUserId, startedAt])
  @@index([watched])
  @@index([referenceId])
  // Powers the arc-detection window functions in getMostPopularOnServer — partition key
  // (user, tmdbId, mediaType, season, episode) ordered by startedAt lets Postgres skip the sort.
  @@index([mediaServerUserId, tmdbId, mediaType, seasonNumber, episodeNumber, startedAt])
  // /admin/activity filters and getPlayHistoryStats both narrow by source+time
  // range or mediaType+time range. Composite indexes let the planner serve the
  // 30+ range-scoped aggregate queries from a smaller heap when filters are set.
  @@index([source, startedAt(sort: Desc)])
  @@index([mediaType, startedAt(sort: Desc)])
}

model ActiveSession {
  id     String @id @db.VarChar(256) // source:sessionKey composite
  source String @db.VarChar(16) // "plex" | "jellyfin"

  sessionKey String   @db.VarChar(256)
  startedAt  DateTime
  lastSeenAt DateTime
  state      String   @db.VarChar(16) // "playing" | "paused" | "buffering"

  // User
  mediaServerUserId String
  mediaServerUser   MediaServerUser @relation(fields: [mediaServerUserId], references: [id], onDelete: Restrict)
  serverUsername    String          @db.VarChar(256)

  // Media
  tmdbId        Int?
  mediaType     String?  @db.VarChar(16)
  title         String   @db.VarChar(500)
  year          String?  @db.VarChar(16)
  seasonNumber  Int?
  episodeNumber Int?
  episodeTitle  String?  @db.VarChar(500)
  sourceItemId  String?  @db.VarChar(256)

  posterPath String?    @db.VarChar(500) // populated from TmdbMediaCore on session create

  // Progress
  progressPercent Float  @default(0)
  progressMs      BigInt @default(0) // Playhead position in the file (last known viewOffset / PlaybackPositionTicks). Drives PlayHistory.completed.
  // Wall-clock timestamp of the last poll that observed progressMs increasing. Drives Plex
  // stall detection: when Plex keeps a session in /status/sessions after the client quit
  // (mobile/TV especially, up to 30 min), the playhead freezes while state still reports
  // "playing". progressUpdatedAt aging past STALL_THRESHOLD_MS in that state finalizes the
  // session early instead of waiting on cleanupStaleSessions(30).
  progressUpdatedAt DateTime @default(now())
  playtimeMs      BigInt @default(0) // Accumulated wall-clock ms spent in the "playing" state. Drives PlayHistory.playDuration / watched.
  durationMs      BigInt @default(0)

  // Playback metadata
  platform      String?  @db.VarChar(256)
  player        String?  @db.VarChar(256)
  device        String?  @db.VarChar(256)
  ipAddress     String?  @db.VarChar(64)
  playMethod    String?  @db.VarChar(32)
  videoCodec    String?  @db.VarChar(64)
  audioCodec    String?  @db.VarChar(64)
  resolution    String?  @db.VarChar(32)
  bitrate       Int?
  videoDecision String?  @db.VarChar(32)
  audioDecision String?  @db.VarChar(32)
  container     String?  @db.VarChar(32)
  transcodeReason String? @db.VarChar(500)

  // Network connection metadata (Plex). See PlayHistory.location/bandwidth/secure/relayed.
  location  String? @db.VarChar(16)
  bandwidth Int?
  secure    Boolean?
  relayed   Boolean?

  // Intro/credits markers fetched once at session start. The values stay
  // pinned through the playback so finalize can stamp them on PlayHistory
  // without a re-fetch of /library/metadata at stop time.
  introStartMs   Int?
  introEndMs     Int?
  creditsStartMs Int?
  creditsEndMs   Int?

  @@unique([source, sessionKey])
  @@index([source])
}

// ─── IP Geolocation Cache ────────────────────────────────────────────────────
// Cached ipinfo.io lookups, keyed by IP. `notFound=true` means the IP is bogon
// (RFC1918, loopback, etc) or upstream returned no data — short-TTL re-checked.
model IpLookupCache {
  ip        String   @id @db.VarChar(64)
  hostname  String?  @db.VarChar(256)
  city      String?  @db.VarChar(128)
  region    String?  @db.VarChar(128)
  country   String?  @db.VarChar(8) // ISO 3166-1 alpha-2
  postal    String?  @db.VarChar(32)
  latitude  Float?
  longitude Float?
  timezone  String?  @db.VarChar(64)
  org       String?  @db.VarChar(256) // e.g. "AS7018 AT&T Enterprises, LLC"
  notFound  Boolean  @default(false)
  fetchedAt DateTime @default(now())

  @@index([fetchedAt])
}

// ─── TRaSH Guides ────────────────────────────────────────────────────────────

// Upstream custom formats, quality profiles, naming, and quality-size specs
// pulled from the TRaSH-Guides repo (Recyclarr was dropped in c0fe663 — TRaSH
// now publishes quality profile JSON directly).
// Keyed by the upstream trash_id so we can match against Radarr/Sonarr CFs that
// have been imported via the TRaSH convention.
model TrashSpec {
  id           String        @id @default(cuid(2))
  trashId      String
  service      TrashService
  kind         TrashSpecKind
  name         String
  description  String?
  payload      Json
  upstreamPath String
  upstreamSha  String?
  fetchedAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  applications TrashApplication[]

  @@unique([service, kind, trashId])
  @@index([service, kind])
}

// One row per spec the admin has chosen to push to Radarr/Sonarr. `enabled=false`
// is the unmanage escape hatch — the sync job ignores it. `remoteId` tracks the
// id Radarr/Sonarr assigned on first apply so we can PUT (overwrite) on subsequent
// syncs without depending on name lookups.
model TrashApplication {
  id          String    @id @default(cuid(2))
  trashSpecId String
  trashSpec   TrashSpec @relation(fields: [trashSpecId], references: [id], onDelete: Cascade)
  // false = HD instance (radarrUrl/sonarrUrl); true = 4K instance (radarr4kUrl/sonarr4kUrl).
  // A spec can be managed independently on each instance — each variant keeps its own remoteId,
  // appliedAt, and error state. The catalog (TrashSpec) is shared across variants.
  is4k        Boolean   @default(false)
  enabled     Boolean   @default(true)
  remoteId    Int?
  appliedAt   DateTime?
  lastError   String?
  // Set whenever lastError is written. Together with errorCount this lets the diagnostic endpoint
  // surface "flapping" specs (errorCount >= 3 within the last 24h) and lets the UI show a
  // "× N failures since 2h ago" badge. Reset to null on a successful apply.
  lastErrorAt DateTime?
  errorCount  Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([trashSpecId, is4k])
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum TrashService {
  RADARR
  SONARR
}

enum TrashSpecKind {
  CUSTOM_FORMAT
  CUSTOM_FORMAT_GROUP
  QUALITY_PROFILE
  NAMING
  QUALITY_SIZE
}

enum Role {
  USER
  ISSUE_ADMIN
  ADMIN
}

// Personal "save for later" list. Unlike DeletionVote it is NOT gated on the
// item being in a library — the whole point is to bookmark things that are not
// yet available. Title/posterPath are denormalized (like DeletionVote) so the
// watchlist page renders without a TMDB round-trip per row.
model WatchlistItem {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())

  tmdbId     Int
  mediaType  MediaType
  title      String  @db.VarChar(500)
  posterPath String? @db.VarChar(500)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tmdbId, mediaType]) // one watchlist entry per user per item
  @@index([userId, createdAt])
}

// Per-user "not interested" / hide list. Distinct from the admin-global
// BlacklistItem: HiddenItem is per-user and REMOVES a title from that user's
// discovery (attachAllAvailability filters it out), whereas the admin blacklist
// keeps a title visible-but-unrequestable for everyone. Title/posterPath are
// denormalized so the "Hidden" management page renders without a TMDB fetch.
model HiddenItem {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())

  tmdbId     Int
  mediaType  MediaType
  title      String  @db.VarChar(500)
  posterPath String? @db.VarChar(500)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tmdbId, mediaType]) // one hide entry per user per item
  @@index([userId, createdAt])
}

enum MediaType {
  MOVIE
  TV
}

enum RequestStatus {
  PENDING
  APPROVED
  DECLINED
  AVAILABLE
}

enum IssueType {
  BAD_VIDEO
  WRONG_AUDIO
  MISSING_SUBTITLES
  WRONG_MATCH
  OTHER
}

enum IssueScope {
  FULL
  SEASON
  EPISODE
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

model WebhookReplay {
  digest    String   @id @db.VarChar(64)
  expiresAt DateTime

  @@index([expiresAt])
}
